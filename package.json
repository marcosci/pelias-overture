{
  "name": "pelias-overture",
  "version": "0.1.0-alpha.0",
  "description": "Pelias importer for Overture Maps data (addresses, places)",
  "main": "index.js",
  "bin": {
    "pelias-overture": "./bin/start"
  },
  "scripts": {
    "start": "./bin/start",
    "test": "jest --coverage",
    "test:unit": "jest test/unit",
    "test:integration": "jest test/integration",
    "test:e2e": "jest test/e2e --runInBand",
    "lint": "eslint lib bin/start test",
    "lint:fix": "eslint --fix lib bin/start test",
    "benchmark:parquet": "node scripts/benchmark-parquet-reader.js",
    "es:create-index": "node scripts/create-pelias-index.js",
    "es:drop-index": "node scripts/drop-pelias-index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcosci/pelias-overture.git"
  },
  "keywords": [
    "pelias",
    "geocoder",
    "overture",
    "overturemaps",
    "importer",
    "geoparquet",
    "duckdb",
    "gers"
  ],
  "author": "Marco Sciaini",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/marcosci/pelias-overture/issues"
  },
  "homepage": "https://github.com/marcosci/pelias-overture#readme",
  "dependencies": {
    "@duckdb/node-api": "^1.5.2-r.1",
    "elasticsearch": "^16.7.3",
    "joi": "^17.13.3",
    "pelias-blacklist-stream": "^1.4.0",
    "pelias-config": "^6.1.0",
    "pelias-dbclient": "^3.3.0",
    "pelias-logger": "^1.6.0",
    "pelias-model": "^10.6.0",
    "pelias-schema": "^9.1.0",
    "pelias-wof-admin-lookup": "^7.17.0",
    "through2": "^4.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.17.0",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "testcontainers": "^10.16.0"
  }
}
